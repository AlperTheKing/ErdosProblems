+private lemma mem_B {A B : Finset ℤ} (hunion : A ∪ B = Finset.Icc 1 6) {b : ℤ}
+    (hb6 : b ∈ Finset.Icc (1 : ℤ) 6) (hbA : b ∉ A) : b ∈ B := by
+  have hbu : b ∈ A ∪ B := by
+    rw [hunion]
