+private lemma prime_dvd_prime_mul_prime {p a b : ℕ} (hp : p.Prime) (ha : a.Prime)
+    (hb : b.Prime) (h : p ∣ a * b) : p = a ∨ p = b := by
+  rcases hp.dvd_mul.mp h with hpa | hpb
+  · exact Or.inl ((Nat.prime_dvd_prime_iff_eq hp ha).mp hpa)
+  · exact Or.inr ((Nat.prime_dvd_prime_iff_eq hp hb).mp hpb)
