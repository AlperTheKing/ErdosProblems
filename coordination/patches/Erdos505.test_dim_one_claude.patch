+private lemma cover_of_pair (S : Set (EuclideanSpace ℝ (Fin 1)))
+    (hS : Bornology.IsBounded S)
+    (p q : EuclideanSpace ℝ (Fin 1)) (hp : p ∈ S) (hq : q ∈ S)
+    (hpq : coord p < coord q) :
+    ∃ F : Fin 2 → Set (EuclideanSpace ℝ (Fin 1)),
+      S ⊆ ⋃ i, F i ∧ ∀ i, diam (F i) < diam S := by
+  set c : ℝ := (coord p + coord q) / 2 with hc
+  set δ : ℝ := (coord q - coord p) / 2 with hδ
+  have hδpos : 0 < δ := by rw [hδ]; linarith
+  have hpqdist : dist p q ≤ diam S := dist_le_diam_of_mem hS hp hq
+  rw [dist_coord, abs_of_neg (by linarith : coord p - coord q < 0)] at hpqdist
+  refine ⟨![S ∩ {x | coord x ≤ c}, S ∩ {x | c ≤ coord x}], ?_, ?_⟩
+  · intro x hx
+    rw [Set.mem_iUnion]
