+    · exact ⟨0, hx, hle⟩
+    · exact ⟨1, hx, hge⟩
+  · intro i
+    have hCnonneg : 0 ≤ diam S - δ := by linarith
+    have hClt : diam S - δ < diam S := by linarith
+    fin_cases i
+    · show diam (S ∩ {x | coord x ≤ c}) < diam S
+      refine lt_of_le_of_lt (diam_le_of_forall_dist_le hCnonneg ?_) hClt
+      intro x hx y hy
+      simp only [Set.mem_inter_iff, Set.mem_setOf_eq] at hx hy
+      obtain ⟨hxS, hxc⟩ := hx
