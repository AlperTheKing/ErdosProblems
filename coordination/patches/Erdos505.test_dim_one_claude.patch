+/-- The single coordinate of a point of the one-dimensional Euclidean line. -/
+private def coord (x : EuclideanSpace ℝ (Fin 1)) : ℝ := x 0
+
+/-- In `EuclideanSpace ℝ (Fin 1)` the distance is the absolute difference of coordinates. -/
+private lemma dist_coord (x y : EuclideanSpace ℝ (Fin 1)) :
+    dist x y = |coord x - coord y| := by
+  simp only [coord]
+  rw [EuclideanSpace.dist_eq, Fin.sum_univ_one, Real.dist_eq, sq_abs, Real.sqrt_sq_eq_abs]
+
